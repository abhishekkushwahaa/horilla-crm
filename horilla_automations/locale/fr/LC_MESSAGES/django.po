msgid ""
"Module for automating mail and notifications based on model events and "
"conditions."
msgstr ""
"Module pour automatiser les e-mails et les notifications basés sur les événements et conditions du modèle."

msgid "Automations"
msgstr "Automatisations"

msgid "Mail & Notifications"
msgstr "E-mail & Notifications"

